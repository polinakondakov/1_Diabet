if (type == 1) {
    double dur, acc_mag, angle_deg;
    double pitch_angle_deg;  // ← НОВЫЙ ВВОД для вертикального движения
    double roll_amp, pitch_amp;
    
    cout << "Duration (sec): "; cin >> dur;
    cout << "Horizontal direction (0=north, 90=east): "; cin >> angle_deg;
    cout << "Pitch angle (positive=up, degrees): "; cin >> pitch_angle_deg;  // ← НОВОЕ
    cout << "Acceleration magnitude (m/s²): "; cin >> acc_mag;
    cout << "Roll amplitude (degrees): "; cin >> roll_amp;
    cout << "Pitch amplitude (degrees): "; cin >> pitch_amp;
    
    double yaw_rad = angle_deg * PI / 180.0;
    double pitch_rad = pitch_angle_deg * PI / 180.0;
    
    double speed = current_vel.length();
    double v_horiz = speed * cos(pitch_rad);
    double v_vert = speed * sin(pitch_rad);
    
    Vector3 new_vel(
        v_horiz * sin(yaw_rad),
        v_horiz * cos(yaw_rad),
        v_vert
    );
    
    double a_horiz = acc_mag * cos(pitch_rad);
    double a_vert = acc_mag * sin(pitch_rad);
    
    Vector3 acc_vec(
        a_horiz * sin(yaw_rad),
        a_horiz * cos(yaw_rad),
        a_vert
    );
    
    generator.addStraight(dur, new_vel, acc_vec, angle_deg,
                          roll_amp, pitch_amp, interval_min, interval_max);
    
    // Обновление состояния для следующего сегмента
    StraightSegment temp(dur, new_vel, acc_vec, angle_deg,
                         roll_amp, pitch_amp, interval_min, interval_max);
    current_pos = current_pos + temp.position(dur);
    current_vel = temp.velocity(dur);
}

#pragma once
#include "core/Vector3.h"

class SmoothTurn {
private:
    Vector3 v1, v2;           // начальная и конечная скорость
    Vector3 o1, o2;           // начальная и конечная ориентация (roll, pitch, yaw в градусах)
    double duration;          // длительность поворота
    double speed1, speed2;    // модули скоростей

public:
    SmoothTurn(Vector3 vel_a, Vector3 vel_b, 
               Vector3 ori_a, Vector3 ori_b, 
               double turn_duration, double max_acc);
    
    Vector3 getVel(double t) const;      // интерполированная скорость
    Vector3 getOrientation(double t) const;  // интерполированная ориентация
    
    double getDuration() const { return duration; }
};

#include "SmoothTurn.h"
#include <cmath>
#include <algorithm>

const double PI = 3.141592653589793;

SmoothTurn::SmoothTurn(Vector3 vel_a, Vector3 vel_b, 
                       Vector3 ori_a, Vector3 ori_b, 
                       double turn_duration, double max_acc)
    : v1(vel_a), v2(vel_b), o1(ori_a), o2(ori_b), duration(turn_duration), 
      speed1(vel_a.length()), speed2(vel_b.length()) {
    
    double speed = speed1;
    if (speed < 0.1) return;
    
    // Угол поворота в горизонтальной плоскости (для центростремительного ускорения)
    double angle1 = atan2(v1.y, v1.x);
    double angle2 = atan2(v2.y, v2.x);
    
    double delta = angle2 - angle1;
    while (delta > PI) delta -= 2 * PI;
    while (delta < -PI) delta += 2 * PI;
    
    if (fabs(delta) < 0.01) return;
    
    // Минимальное время из центростремительного ускорения
    double R_min = (speed * speed) / max_acc;
    double d_min = R_min * tan(fabs(delta) / 2.0);
    double min_duration = d_min / speed;
    
    if (duration < min_duration) duration = min_duration;
    if (duration < 0.05) duration = 0.05;
}

Vector3 SmoothTurn::getVel(double t) const {
    double u = t / duration;
    if (u > 1.0) u = 1.0;
    
    // Smoothstep интерполяция для направления
    double s = u * u * (3 - 2 * u);
    
    Vector3 d1 = v1.normalized();
    Vector3 d2 = v2.normalized();
    
    Vector3 dir = d1 * (1 - s) + d2 * s;
    dir = dir.normalized();
    
    // Интерполяция модуля скорости
    double speed = speed1 * (1 - u) + speed2 * u;
    
    return dir * speed;
}

Vector3 SmoothTurn::getOrientation(double t) const {
    double u = t / duration;
    if (u > 1.0) u = 1.0;
    
    // Smoothstep интерполяция для углов
    double s = u * u * (3 - 2 * u);
    
    // Интерполяция углов с учётом циклического характера (yaw может переходить через 360°)
    double roll = o1.x * (1 - s) + o2.x * s;
    double pitch = o1.y * (1 - s) + o2.y * s;
    
    double yaw1 = o1.z;
    double yaw2 = o2.z;
    
    // Учёт перехода через 0/360 градусов
    double delta_yaw = yaw2 - yaw1;
    if (delta_yaw > 180) delta_yaw -= 360;
    if (delta_yaw < -180) delta_yaw += 360;
    
    double yaw = yaw1 + delta_yaw * s;
    
    // Нормализация yaw в диапазон [0, 360)
    if (yaw < 0) yaw += 360;
    if (yaw >= 360) yaw -= 360;
    
    return Vector3(roll, pitch, yaw);
}
vector<TrajectoryPoint> TrajectoryGenerator::buildWithSmoothing(double max_normal_acc) {
    if (config.witch_from) {
        return loadFromFile(config.file_path);
    }

    vector<TrajectoryPoint> trajectory;
    double current_time = 0;
    Vector3 pos(0, 0, 0);      // абсолютная позиция в ENU (метры)
    Vector3 vel(0, 0, 0);      // текущая скорость
    Vector3 ori(0, 0, 0);      // текущая ориентация (roll, pitch, yaw)

    if (config.segments.empty()) {
        cout << "No segments for generation" << endl;
        return trajectory;
    }

    for (size_t i = 0; i < config.segments.size(); i++) {
        auto& seg = config.segments[i];
        double duration = seg->duration;

        // ===== ГЕНЕРАЦИЯ ТОЧЕК СЕГМЕНТА =====
        for (double t = 0; t < duration; t += config.time_step) {
            vel = seg->velocity(t);
            pos = pos + vel * config.time_step;
            ori = seg->orientation(t);

            TrajectoryPoint point(current_time + t);
            point.position = pos;
            point.velocity = vel;
            point.acceleration = seg->acceleration(t);
            point.orientation = ori;
            point.angular_velocity = seg->angular_velocity(t);
            point.geo_position = ISOToGeo(point.position, config.start_geo_position);

            trajectory.push_back(point);
        }

        // Добавляем последнюю точку сегмента
        vel = seg->velocity(duration);
        pos = pos + vel * (duration - floor(duration / config.time_step) * config.time_step);
        ori = seg->orientation(duration);

        TrajectoryPoint last_point(current_time + duration);
        last_point.position = pos;
        last_point.velocity = vel;
        last_point.acceleration = seg->acceleration(duration);
        last_point.orientation = ori;
        last_point.angular_velocity = seg->angular_velocity(duration);
        last_point.geo_position = ISOToGeo(last_point.position, config.start_geo_position);
        trajectory.push_back(last_point);

        current_time += duration;

        // ===== ПЛАВНЫЙ ПОВОРОТ МЕЖДУ СЕГМЕНТАМИ =====
        if (i < config.segments.size() - 1) {
            // Скорости
            Vector3 endVel = seg->velocity(duration);
            Vector3 nextVel = config.segments[i+1]->velocity(0);
            
            // Ориентации
            Vector3 endOri = seg->orientation(duration);
            Vector3 nextOri = config.segments[i+1]->orientation(0);
            
            // Длительность поворота (для окружностей короче)
            double turn_duration = 1.0;
            if (seg->getType() == 3 || config.segments[i+1]->getType() == 3) {
                turn_duration = 0.3;
            }
            
            // Создаём объект плавного поворота (3D версия)
            SmoothTurn turn(endVel, nextVel, endOri, nextOri, turn_duration, max_normal_acc);
            
            // Начальная позиция для поворота
            Vector3 turn_start_pos = pos;
            
            // Генерируем точки поворота
            for (double t = config.time_step; t <= turn.getDuration(); t += config.time_step) {
                if (t > turn.getDuration()) t = turn.getDuration();
                
                vel = turn.getVel(t);
                ori = turn.getOrientation(t);
                pos = turn_start_pos + vel * t;
                
                TrajectoryPoint point(current_time + t);
                point.position = pos;
                point.velocity = vel;
                point.orientation = ori;
                point.geo_position = ISOToGeo(point.position, config.start_geo_position);
                
                trajectory.push_back(point);
            }
            
            // Обновляем время и позицию после поворота
            current_time += turn.getDuration();
            pos = turn_start_pos + turn.getVel(turn.getDuration()) * turn.getDuration();
            vel = turn.getVel(turn.getDuration());
            ori = turn.getOrientation(turn.getDuration());
        }
    }

    return trajectory;
}
