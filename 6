#include "TrajectorySegment.h"

class CircleSegment : public TrajectorySegment {
private:
    Vector3 center_;
    double radius_;
    double angular_vel_;
    double start_angle_;

public:
    CircleSegment(double duration, Vector3 center, double radius, double angular_vel, double start_angle);
    
    Vector3 position(double t) const override;
    Vector3 velocity(double t) const override;
    Vector3 acceleration(double t) const override;
    Vector3 orientation(double t) const override;
    Vector3 angular_velocity(double t) const override;
    int getType() const override { return 3; }
};
#include "CircleSegment.h"
#include <cmath>

CircleSegment::CircleSegment(double duration, Vector3 center, double radius, double angular_vel, double start_angle)
    : TrajectorySegment(duration), center_(center), radius_(radius), angular_vel_(angular_vel), start_angle_(start_angle) {}

Vector3 CircleSegment::position(double t) const {
    double angle = start_angle_ + angular_vel_ * t;
    return Vector3(radius_ * cos(angle), radius_ * sin(angle), 0);
}

Vector3 CircleSegment::velocity(double t) const {
    double angle = start_angle_ + angular_vel_ * t;
    return Vector3(-radius_ * angular_vel_ * sin(angle), radius_ * angular_vel_ * cos(angle), 0);
}

Vector3 CircleSegment::acceleration(double t) const {
    double angle = start_angle_ + angular_vel_ * t;
    return Vector3(-radius_ * angular_vel_ * angular_vel_ * cos(angle), -radius_ * angular_vel_ * angular_vel_ * sin(angle), 0);
}

Vector3 CircleSegment::orientation(double t) const {
    Vector3 v = velocity(t);
    double len = v.length();
    if (len > 1e-6) return v / len;
    return Vector3(1, 0, 0);
}

Vector3 CircleSegment::angular_velocity(double t) const {
    return Vector3(0, 0, angular_vel_);
}
