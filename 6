#include "TrajectorySegment.h"

class SnakeSegment : public TrajectorySegment {
private:
    double forward_vel_;
    double amplitude_;
    double frequency_;
    double direction_angle_;

public:
    SnakeSegment(double duration, double forward_vel, double amplitude, double frequency, double direction_angle);
    
    Vector3 position(double t) const override;
    Vector3 velocity(double t) const override;
    Vector3 acceleration(double t) const override;
    Vector3 orientation(double t) const override;
    Vector3 angular_velocity(double t) const override;
    int getType() const override { return 2; }
};
#include "SnakeSegment.h"
#include <cmath>

const double PI = 3.141592653589793;

SnakeSegment::SnakeSegment(double duration, double forward_vel, double amplitude, double frequency, double direction_angle)
    : TrajectorySegment(duration), forward_vel_(forward_vel), amplitude_(amplitude), frequency_(frequency), direction_angle_(direction_angle) {}

Vector3 SnakeSegment::position(double t) const {
    double omega = 2 * PI * frequency_;
    double dir_x = cos(direction_angle_);
    double dir_y = sin(direction_angle_);
    double perp_x = -dir_y;
    double perp_y = dir_x;
    
    double forward_dist = forward_vel_ * t;
    double lateral_dist = amplitude_ * sin(omega * t);
    
    return Vector3(
        forward_dist * dir_x + lateral_dist * perp_x,
        forward_dist * dir_y + lateral_dist * perp_y,
        0
    );
}

Vector3 SnakeSegment::velocity(double t) const {
    double omega = 2 * PI * frequency_;
    double dir_x = cos(direction_angle_);
    double dir_y = sin(direction_angle_);
    double perp_x = -dir_y;
    double perp_y = dir_x;
    
    return Vector3(
        forward_vel_ * dir_x + amplitude_ * omega * cos(omega * t) * perp_x,
        forward_vel_ * dir_y + amplitude_ * omega * cos(omega * t) * perp_y,
        0
    );
}

Vector3 SnakeSegment::acceleration(double t) const {
    double omega = 2 * PI * frequency_;
    double dir_x = cos(direction_angle_);
    double dir_y = sin(direction_angle_);
    double perp_x = -dir_y;
    double perp_y = dir_x;
    
    return Vector3(
        -amplitude_ * omega * omega * sin(omega * t) * perp_x,
        -amplitude_ * omega * omega * sin(omega * t) * perp_y,
        0
    );
}

Vector3 SnakeSegment::orientation(double t) const {
    Vector3 v = velocity(t);
    double len = v.length();
    if (len > 1e-6) return v / len;
    return Vector3(1, 0, 0);
}

Vector3 SnakeSegment::angular_velocity(double t) const {
    Vector3 v = velocity(t);
    Vector3 a = acceleration(t);
    double vx = v.x, vy = v.y;
    double ax = a.x, ay = a.y;
    double v_len2 = vx*vx + vy*vy;
    if (v_len2 < 1e-6) return Vector3(0, 0, 0);
    double omega_z = (vx * ay - vy * ax) / v_len2;
    return Vector3(0, 0, omega_z);
}
#pragma once
#include "core/Vector3.h"

class SmoothTurn {
public:
    Vector3 v1, v2;
    double duration;
    double speed1, speed2;
    
    SmoothTurn(Vector3 a, Vector3 b, double d, double max_acc = 0);
    
    Vector3 getVel(double t) const;
};
#include "SmoothTurn.h"
#include <cmath>

const double PI = 3.141592653589793;

SmoothTurn::SmoothTurn(Vector3 a, Vector3 b, double d, double max_acc)
    : v1(a), v2(b), duration(d), speed1(a.length()), speed2(b.length()) {
    
    double speed = speed1;
    if (speed < 0.1) return;
    
    double angle1 = atan2(v1.y, v1.x);
    double angle2 = atan2(v2.y, v2.x);
    
    double delta = angle2 - angle1;
    while (delta > PI) delta -= 2 * PI;
    while (delta < -PI) delta += 2 * PI;
    
    if (fabs(delta) < 0.01) return;
    
    double R_min = (speed * speed) / max_acc;
    double d_min = R_min * tan(fabs(delta) / 2.0);
    double min_duration = d_min / speed;
    
    if (duration < min_duration) duration = min_duration;
    if (duration < 0.05) duration = 0.05;
}

Vector3 SmoothTurn::getVel(double t) const {
    double u = t / duration;
    if (u > 1.0) u = 1.0;
    
    double s = u * u * (3 - 2 * u);
    
    Vector3 d1 = v1.normalized();
    Vector3 d2 = v2.normalized();
    
    Vector3 dir = d1 * (1 - s) + d2 * s;
    dir = dir.normalized();
    
    double speed = speed1 * (1 - u) + speed2 * u;
    
    return dir * speed;
}
