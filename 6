using namespace std;

const double PI = 3.141592653589793;

int main() {
    cout << "=== MOTION SENSORS SIMULATOR ===" << endl;

    TrajectoryConfig config;

    cout << "1 - Analytical, 2 - From file: ";
    int mode; cin >> mode;
    config.witch_from = (mode == 2);

    if (!config.witch_from) {
        cout << "Time step (sec): "; cin >> config.time_step;
        cout << "Start lat: "; cin >> config.start_geo_position.latitude;
        cout << "Start lon: "; cin >> config.start_geo_position.longitude;
        cout << "Start alt: "; cin >> config.start_geo_position.altitude;

        double start_speed, start_acc;
        cout << "Start speed (m/s): "; cin >> start_speed;
        cout << "Start acceleration (m/s²): "; cin >> start_acc;

        Vector3 start_vel(0, start_speed, 0);
        Vector3 start_acc_vec(0, start_acc, 0);

        cout << "Number of trajectory segments: "; int segs; cin >> segs;

        Vector3 current_pos(0, 0, 0);
        Vector3 current_vel = start_vel;
        double current_abs_angle = 0.0;

        TrajectoryGenerator generator(config);

        for (int i = 0; i < segs; i++) {
            cout << "\nSegment " << i + 1 << " type (1=straight, 2=snake, 3=circle): ";
            int type; cin >> type;

            if (type == 1) {
                double dur, acc_mag, angle_deg;
                cout << "Duration: "; cin >> dur;
                cout << "Direction angle (degrees, 0=north, 90=east): "; cin >> angle_deg;
                cout << "Acceleration magnitude: "; cin >> acc_mag;

                double abs_angle_rad = angle_deg * PI / 180.0;
                double speed = current_vel.length();
                
                Vector3 new_vel(speed * sin(abs_angle_rad), speed * cos(abs_angle_rad), 0);
                Vector3 acc_vec(acc_mag * sin(abs_angle_rad), acc_mag * cos(abs_angle_rad), 0);

                generator.addStraight(dur, current_pos, new_vel, acc_vec, angle_deg);
                
                current_pos = current_pos + new_vel * dur + acc_vec * (0.5 * dur * dur);
                current_vel = new_vel + acc_vec * dur;
            }
            else if (type == 2) {
                double dur, vx, A, f;
                cout << "Duration: "; cin >> dur;
                cout << "Forward velocity X (m/s): "; cin >> vx;
                cout << "Amplitude: "; cin >> A;
                cout << "Frequency: "; cin >> f;

                generator.addSnake(dur, current_pos, vx, A, f);

                double omega = 2 * PI * f;
                current_pos = Vector3(current_pos.x + vx * dur, current_pos.y + A * sin(omega * dur), current_pos.z);
                current_vel = Vector3(vx, A * omega * cos(omega * dur), 0);
                current_abs_angle = atan2(current_vel.x, current_vel.y);
            }
            else if (type == 3) {
                double dur, R, w;
                cout << "Duration: "; cin >> dur;
                cout << "Radius: "; cin >> R;
                cout << "Angular velocity (rad/s): "; cin >> w;

                Vector3 vel_dir = current_vel.normalized();
                Vector3 perp;
                if (w > 0) perp = Vector3(-vel_dir.y, vel_dir.x, 0);
                else perp = Vector3(vel_dir.y, -vel_dir.x, 0);

                Vector3 center = current_pos + perp * R;
                double start_angle = atan2(current_pos.y - center.y, current_pos.x - center.x);

                generator.addCircle(dur, center, R, w, start_angle);

                double end_angle = start_angle + w * dur;
                current_pos = Vector3(center.x + R * cos(end_angle), center.y + R * sin(end_angle), center.z);
                current_vel = Vector3(-R * w * sin(end_angle), R * w * cos(end_angle), 0);
                current_abs_angle = atan2(current_vel.x, current_vel.y);
            }
        }

        double max_normal_acc;
        cout << "\nMax normal acceleration for smoothing (m/s²): "; cin >> max_normal_acc;

        auto trajectory = generator.buildWithSmoothing(max_normal_acc);

        string traj_filename;
        cout << "Output trajectory filename: "; cin >> traj_filename;

        ofstream traj_file(traj_filename);
        traj_file << "Time,PosX,PosY,PosZ,VelX,VelY,VelZ,AccX,AccY,AccZ,AngVelX,AngVelY,AngVelZ,Roll,Pitch,Yaw,Latitude,Longitude,Altitude\n";
        for (const auto& point : trajectory) {
            if (point.isValid()) traj_file << point.toCSV() << "\n";
        }
        traj_file.close();
        cout << "True trajectory saved! " << trajectory.size() << " points\n";

        // Датчики
        vector<shared_ptr<Sensor>> sensors;

        cout << "\n=== SENSORS CONFIGURATION ===" << endl;
        cout << "Number of sensors: "; int n; cin >> n;
        
        for (int i = 0; i < n; i++) {
            cout << "\nSensor " << i + 1 << ":" << endl;
            cout << "1 - Accelerometer, 2 - Gyroscope, 3 - GNSS: ";
            int type; cin >> type;
            cout << "Frequency (Hz): "; double f; cin >> f;

            if (type == 1) {
                cout << "Bias X Y Z (m/s²): "; double bx, by, bz; cin >> bx >> by >> bz;
                cout << "Noise (m/s²): "; double noise; cin >> noise;
                sensors.push_back(make_shared<Accelerometer>(f, bx, by, bz, noise, generator.transforms));
            }
            else if (type == 2) {
                cout << "Bias X Y Z (rad/s): "; double bx, by, bz; cin >> bx >> by >> bz;
                cout << "Noise (rad/s): "; double noise; cin >> noise;
                sensors.push_back(make_shared<Gyroscope>(f, bx, by, bz, noise));
            }
            else if (type == 3) {
                cout << "Noise latitude (m): "; double n_lat; cin >> n_lat;
                cout << "Noise longitude (m): "; double n_lon; cin >> n_lon;
                cout << "Noise altitude (m): "; double n_alt; cin >> n_alt;
                sensors.push_back(make_shared<GNSS>(f, n_lat, n_lon, n_alt));
            }
        }

        vector<vector<shared_ptr<SensorMeasurement>>> sensor_measurements;
        for (size_t i = 0; i < sensors.size(); ++i) {
            sensor_measurements.emplace_back();
        }

        cout << "\n=== SIMULATION ===" << endl;
        for (size_t step = 0; step < trajectory.size(); ++step) {
            const TrajectoryPoint& state = trajectory[step];
            
            for (size_t i = 0; i < sensors.size(); ++i) {
                auto measurement = sensors[i]->getMeasurement(state);
                sensor_measurements[i].push_back(measurement);
            }
        }
        cout << "Simulation complete. Processed " << trajectory.size() << " points\n";

        string meas_filename;
        cout << "\nOutput measurements filename: "; cin >> meas_filename;

        ofstream meas_file(meas_filename);
        if (!meas_file.is_open()) {
            cout << "Error opening file: " << meas_filename << endl;
            return 0;
        }

        meas_file << "Time";
        for (const auto& sensor : sensors) {
            string name = sensor->getName();
            if (name.find("GNSS") != string::npos) {
                meas_file << "," << name << "_Lat," << name << "_Lon," << name << "_Alt";
            } else {
                meas_file << "," << name << "_X," << name << "_Y," << name << "_Z";
            }
        }
        meas_file << "\n";

        if (!sensor_measurements.empty() && !sensor_measurements[0].empty()) {
            int num_steps = sensor_measurements[0].size();
            for (int i = 0; i < num_steps; ++i) {
                meas_file << fixed << setprecision(6) << sensor_measurements[0][i]->time;
                
                for (size_t j = 0; j < sensors.size(); ++j) {
                    if (i < sensor_measurements[j].size() && sensor_measurements[j][i]) {
                        meas_file << "," << sensor_measurements[j][i]->toCSV();
                    } else {
                        meas_file << ",,,";
                    }
                }
                meas_file << "\n";
            }
        }
        meas_file.close();
        cout << "Measurements saved to " << meas_filename << endl;

    } else {
        cout << "File: "; cin >> config.file_path;
        cout << "Start lat: "; cin >> config.start_geo_position.latitude;
        cout << "Start lon: "; cin >> config.start_geo_position.longitude;
        cout << "Start alt: "; cin >> config.start_geo_position.altitude;
        config.time_step = 0.1;

        TrajectoryGenerator generator(config);
        auto trajectory = generator.build();

        string filename;
        cout << "Output filename: "; cin >> filename;
        ofstream file(filename);
        file << "Time,PosX,PosY,PosZ,VelX,VelY,VelZ,AccX,AccY,AccZ,AngVelX,AngVelY,AngVelZ,Roll,Pitch,Yaw,Latitude,Longitude,Altitude\n";
        for (const auto& point : trajectory) {
            if (point.isValid()) file << point.toCSV() << "\n";
        }
        file.close();

        cout << "Trajectory saved! " << trajectory.size() << " points\n";
    }

    return 0;
}

