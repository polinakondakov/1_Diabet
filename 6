class Accelerometer : public Sensor {
private:
    double bias_x, bias_y, bias_z;
    double noise;
    mutable std::normal_distribution<double> noise_dist;
    mutable std::default_random_engine generator;
    const CoordinateTransforms& transforms;

public:
    Accelerometer(double freq, double b_x, double b_y, double b_z, double noise,
                  const CoordinateTransforms& tf);
    
    std::shared_ptr<SensorMeasurement> getMeasurement(const TrajectoryPoint& state) override;
};
#include "Accelerometer.h"
#include "VectorMeasurement.h"
#include <chrono>

Accelerometer::Accelerometer(double freq, double b_x, double b_y, double b_z, double noise,
                             const CoordinateTransforms& tf)
    : Sensor(SensorStaticParams("Accelerometer", freq)),
      bias_x(b_x), bias_y(b_y), bias_z(b_z), noise(noise),
      noise_dist(0.0, noise), transforms(tf) {
    auto seed = std::chrono::high_resolution_clock::now().time_since_epoch().count();
    generator.seed(seed);
}

std::shared_ptr<SensorMeasurement> Accelerometer::getMeasurement(const TrajectoryPoint& state) {
    if (!shouldSample(state.time)) {
        return dynamic_state.last_measurement;
    }
    
    // 1. Ускорение в ECI
    Vector3 a_eci = state.acceleration_eci;
    
    // 2. ECI → ECEF
    Vector3 a_ecef = transforms.eciToEcef(a_eci, state.time);
    
    // 3. ECEF → ENU
    Vector3 a_enu = transforms.ecefToEnu(a_ecef, 
                                         state.geo_position.latitude, 
                                         state.geo_position.longitude);
    
    // 4. Вычитаем гравитацию
    a_enu.z -= 9.80665;
    
    // 5. ENU → Body
    Vector3 ideal = transforms.enuToBody(a_enu, 
                                         state.orientation.x, 
                                         state.orientation.y, 
                                         state.orientation.z);
    
    // 6. Добавляем погрешности
    Vector3 measured(
        ideal.x + bias_x + noise_dist(generator),
        ideal.y + bias_y + noise_dist(generator),
        ideal.z + bias_z + noise_dist(generator)
    );
    
    auto measurement = std::make_shared<VectorMeasurement>(state.time, getName(), measured);
    
    dynamic_state.time = state.time;
    dynamic_state.is_valid = measured.isValid();
    if (dynamic_state.is_valid) {
        dynamic_state.last_valid_measurement_time = state.time;
        dynamic_state.last_measurement = measurement;
    }
    last_measurement_time = state.time;
    
    return measurement;
}
#include "trajectory/TrajectoryGenerator.h"
#include "trajectory/StraightSegment.h"
