struct TrajectoryPoint {
    double time = 0;
    
    // ECI координаты (для физики)
    Vector3 position_eci;
    Vector3 velocity_eci;
    Vector3 acceleration_eci;
    
    // Ориентация
    Vector3 orientation;        // roll, pitch, yaw в градусах
    Vector3 angular_velocity;   // рад/с
    
    // Географические координаты (для вывода и GNSS)
    GeoPosition geo_position;
    
    TrajectoryPoint(double t = 0);
    
    std::string toCSV() const;
    bool isValid() const;
};
#include "TrajectoryPoint.h"
#include <sstream>
#include <iomanip>

TrajectoryPoint::TrajectoryPoint(double t) : time(t) {}

std::string TrajectoryPoint::toCSV() const {
    std::stringstream ss;
    ss << std::fixed << std::setprecision(8);
    ss << time << ","
       << position_eci.x << "," << position_eci.y << "," << position_eci.z << ","
       << velocity_eci.x << "," << velocity_eci.y << "," << velocity_eci.z << ","
       << acceleration_eci.x << "," << acceleration_eci.y << "," << acceleration_eci.z << ","
       << angular_velocity.x << "," << angular_velocity.y << "," << angular_velocity.z << ","
       << orientation.x << "," << orientation.y << "," << orientation.z << ","
       << geo_position.latitude << "," << geo_position.longitude << "," << geo_position.altitude;
    return ss.str();
}

bool TrajectoryPoint::isValid() const {
    return !std::isnan(time) && 
           position_eci.isValid() && 
           velocity_eci.isValid() && 
           acceleration_eci.isValid();
}
