class TrajectorySegment {
public:
    double duration;
    
    TrajectorySegment(double d) : duration(d) {}
    virtual ~TrajectorySegment() = default;
    
    virtual Vector3 position(double t) const = 0;
    virtual Vector3 velocity(double t) const = 0;
    virtual Vector3 acceleration(double t) const = 0;
    virtual Vector3 orientation(double t) const = 0;
    virtual Vector3 angular_velocity(double t) const = 0;
    virtual int getType() const = 0;
};
#pragma once
#include "TrajectorySegment.h"

class StraightSegment : public TrajectorySegment {
private:
    Vector3 start_velocity_;
    Vector3 acceleration_;
    double angle_;

public:
    StraightSegment(double duration, Vector3 start_vel, Vector3 acc, double angle);
    
    Vector3 position(double t) const override;
    Vector3 velocity(double t) const override;
    Vector3 acceleration(double t) const override;
    Vector3 orientation(double t) const override;
    Vector3 angular_velocity(double t) const override;
    int getType() const override { return 1; }
};
#include "StraightSegment.h"

StraightSegment::StraightSegment(double duration, Vector3 start_vel, Vector3 acc, double angle)
    : TrajectorySegment(duration), start_velocity_(start_vel), acceleration_(acc), angle_(angle) {}

Vector3 StraightSegment::position(double t) const {
    return start_velocity_ * t + acceleration_ * (0.5 * t * t);
}

Vector3 StraightSegment::velocity(double t) const {
    return start_velocity_ + acceleration_ * t;
}

Vector3 StraightSegment::acceleration(double t) const {
    return acceleration_;
}

Vector3 StraightSegment::orientation(double t) const {
    Vector3 v = velocity(t);
    double len = v.length();
    if (len > 1e-6) return v / len;
    return Vector3(1, 0, 0);
}

Vector3 StraightSegment::angular_velocity(double t) const {
    return Vector3(0, 0, 0);
}
