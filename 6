struct SensorStaticParams {
    std::string name;
    double frequency;
    
    SensorStaticParams(const std::string& n = "", double f = 100.0) : name(n), frequency(f) {}
};

struct SensorDynamicEvent {
    double time = 0;
    bool is_valid = false;
    double last_valid_measurement_time = 0;
    std::shared_ptr<SensorMeasurement> last_measurement;
    
    SensorDynamicEvent(double t = 0) : time(t), last_valid_measurement_time(t) {}
};

class Sensor {
public:
    SensorStaticParams static_params;
    SensorDynamicEvent dynamic_state;
    double last_measurement_time = -1;
    
    Sensor(const SensorStaticParams& params);
    virtual ~Sensor() = default;
    
    std::string getName() const { return static_params.name; }
    
    bool shouldSample(double current_time);
    virtual std::shared_ptr<SensorMeasurement> getMeasurement(const TrajectoryPoint& state) = 0;
};
#include "Sensor.h"

Sensor::Sensor(const SensorStaticParams& params) : static_params(params), dynamic_state(0) {}

bool Sensor::shouldSample(double current_time) {
    if (last_measurement_time < -1) return true;
    double dt = current_time - last_measurement_time;
    return dt >= (1.0 / static_params.frequency);
}
