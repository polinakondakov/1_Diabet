class TrajectoryGenerator {
public:
    TrajectoryConfig config;
    CoordinateTransforms transforms;
    
    TrajectoryGenerator(const TrajectoryConfig& cfg);
    
    vector<TrajectoryPoint> build();
    vector<TrajectoryPoint> buildWithSmoothing(double max_normal_acc);
    vector<TrajectoryPoint> loadFromFile(const string& filename);
    void computeDerivatives(vector<TrajectoryPoint>& traj);
    
    void addStraight(double duration, Vector3 start_pos, Vector3 start_vel, Vector3 acc, double angle);
    void addSnake(double duration, Vector3 start_pos, double forward_vel, double amplitude, double frequency);
    void addCircle(double duration, Vector3 center, double radius, double angular_vel, double start_angle);
};
#include "TrajectoryGenerator.h"
#include "StraightSegment.h"
#include "SnakeSegment.h"
#include "CircleSegment.h"
#include "SmoothTurn.h"
#include <fstream>
#include <sstream>
#include <algorithm>

TrajectoryGenerator::TrajectoryGenerator(const TrajectoryConfig& cfg) : config(cfg) {
    transforms.init(config.start_geo_position, 0);
}

vector<TrajectoryPoint> TrajectoryGenerator::buildWithSmoothing(double max_normal_acc) {
    if (config.witch_from) {
        return loadFromFile(config.file_path);
    }
    
    vector<TrajectoryPoint> trajectory;
    double current_time = 0;
    
    if (config.segments.empty()) {
        cout << "No segments for generation" << endl;
        return trajectory;
    }
    
    // Начальная абсолютная позиция в ECI
    Vector3 abs_pos_eci = transforms.geoToEci(config.start_geo_position, 0);
    
    for (size_t i = 0; i < config.segments.size(); i++) {
        auto& seg = config.segments[i];
        double duration = seg->duration;
        
        // Запоминаем начало сегмента
        Vector3 seg_start_abs = abs_pos_eci;
        
        // Генерация точек сегмента
        for (double t = 0; t <= duration; t += config.time_step) {
            if (t > duration) t = duration;
            
            Vector3 local_pos = seg->position(t);
            Vector3 current_abs_eci = seg_start_abs + local_pos;
            Vector3 current_vel = seg->velocity(t);
            
            TrajectoryPoint point(current_time + t);
            point.position_eci = current_abs_eci;
            point.velocity_eci = current_vel;
            point.acceleration_eci = seg->acceleration(t);
            point.orientation = seg->orientation(t);
            point.angular_velocity = seg->angular_velocity(t);
            point.geo_position = transforms.eciToGeo(current_abs_eci, current_time + t);
            
            trajectory.push_back(point);
        }
        
        // Обновляем позицию после сегмента
        abs_pos_eci = seg_start_abs + seg->position(duration);
        current_time += duration;
        
        // Плавный поворот
        if (i < config.segments.size() - 1) {
            Vector3 endVel = seg->velocity(duration);
            Vector3 nextVel = config.segments[i+1]->velocity(0);
            
            double turn_duration = 1.0;
            if (seg->getType() == 3 || config.segments[i+1]->getType() == 3) {
                turn_duration = 0.3;
            }
            
            SmoothTurn turn(endVel, nextVel, turn_duration, max_normal_acc);
            
            Vector3 turn_start_pos = abs_pos_eci;
            
            for (double t = config.time_step; t <= turn.duration; t += config.time_step) {
                if (t > turn.duration) t = turn.duration;
                
                Vector3 vel = turn.getVel(t);
                Vector3 pos = turn_start_pos + vel * t;
                
                TrajectoryPoint point(current_time + t);
                point.position_eci = pos;
                point.velocity_eci = vel;
                point.geo_position = transforms.eciToGeo(pos, current_time + t);
                
                trajectory.push_back(point);
            }
            
            abs_pos_eci = turn_start_pos + turn.getVel(turn.duration) * turn.duration;
            current_time += turn.duration;
        }
    }
    
    return trajectory;
}

vector<TrajectoryPoint> TrajectoryGenerator::build() {
    if (config.witch_from) {
        return loadFromFile(config.file_path);
    }
    return buildWithSmoothing(100.0);
}

vector<TrajectoryPoint> TrajectoryGenerator::loadFromFile(const string& filename) {
    ifstream file(filename);
    vector<TrajectoryPoint> traj;
    
    if (!file.is_open()) {
        cout << "Error opening file: " << filename << endl;
        return traj;
    }
    
    string line;
    getline(file, line);
    
    while (getline(file, line)) {
        if (line.empty()) continue;
        
        stringstream ss(line);
        vector<double> values;
        string val;
        while (getline(ss, val, ',')) {
            values.push_back(stod(val));
        }
        
        if (values.size() >= 7) {
            TrajectoryPoint p(values[0]);
            p.geo_position = GeoPosition(values[1], values[2], values[3]);
            p.position_eci = transforms.geoToEci(p.geo_position, values[0]);
            p.orientation = Vector3(values[4], values[5], values[6]);
            traj.push_back(p);
        }
    }
    
    computeDerivatives(traj);
    file.close();
    return traj;
}

void TrajectoryGenerator::computeDerivatives(vector<TrajectoryPoint>& traj) {
    if (traj.size() < 2) return;
    
    double dt = traj[1].time - traj[0].time;
    
    for (size_t i = 0; i < traj.size() - 1; i++) {
        traj[i].velocity_eci = (traj[i+1].position_eci - traj[i].position_eci) / dt;
        traj[i].acceleration_eci = (traj[i+1].velocity_eci - traj[i].velocity_eci) / dt;
        
        Vector3 dTheta = traj[i+1].orientation - traj[i].orientation;
        traj[i].angular_velocity = Vector3(dTheta.x/dt, dTheta.y/dt, dTheta.z/dt);
    }
    
    size_t last = traj.size() - 1;
    traj[last].velocity_eci = traj[last-1].velocity_eci;
    traj[last].acceleration_eci = traj[last-1].acceleration_eci;
    traj[last].angular_velocity = traj[last-1].angular_velocity;
}

