#pragma once
#include "Vector3.h"
#include "GeoPosition.h"

class CoordinateTransforms {
private:
    static constexpr double A = 6378137.0;           // большая полуось (м)
    static constexpr double E2 = 0.00669437999014;   // квадрат эксцентриситета
    static constexpr double OMEGA = 7.292115e-5;     // угловая скорость Земли (рад/с)
    static constexpr double PI = 3.141592653589793;
    
    GeoPosition origin;
    double origin_time;
    bool initialized;

public:
    CoordinateTransforms();
    
    void init(const GeoPosition& start_geo, double time = 0);
    
    // Географические ↔ ECEF
    Vector3 geoToEcef(const GeoPosition& geo) const;
    GeoPosition ecefToGeo(const Vector3& ecef) const;
    
    // ECEF ↔ ECI
    double getSiderealTime(double time) const;
    Vector3 ecefToEci(const Vector3& ecef, double time) const;
    Vector3 eciToEcef(const Vector3& eci, double time) const;
    
    // ECEF ↔ ENU
    Vector3 ecefToEnu(const Vector3& ecef, double lat, double lon) const;
    Vector3 enuToEcef(const Vector3& enu, double lat, double lon) const;
    
    // ENU ↔ Body
    Vector3 enuToBody(const Vector3& enu, double roll, double pitch, double yaw) const;
    Vector3 bodyToEnu(const Vector3& body, double roll, double pitch, double yaw) const;
    
    // Полные преобразования
    GeoPosition eciToGeo(const Vector3& eci, double time) const;
    Vector3 geoToEci(const GeoPosition& geo, double time) const;
    
    bool isInitialized() const { return initialized; }
};#include "CoordinateTransforms.h"
#include <cmath>

CoordinateTransforms::CoordinateTransforms() : initialized(false), origin_time(0) {}

void CoordinateTransforms::init(const GeoPosition& start_geo, double time) {
    origin = start_geo;
    origin_time = time;
    initialized = true;
}

// ========== ГЕОГРАФИЧЕСКИЕ ↔ ECEF ==========

Vector3 CoordinateTransforms::geoToEcef(const GeoPosition& geo) const {
    double lat_rad = geo.latitude * PI / 180.0;
    double lon_rad = geo.longitude * PI / 180.0;
    double alt = geo.altitude;
    
    double sin_lat = sin(lat_rad);
    double cos_lat = cos(lat_rad);
    double cos_lon = cos(lon_rad);
    double sin_lon = sin(lon_rad);
    
    double N = A / sqrt(1.0 - E2 * sin_lat * sin_lat);
    
    return Vector3(
        (N + alt) * cos_lat * cos_lon,
        (N + alt) * cos_lat * sin_lon,
        (N * (1.0 - E2) + alt) * sin_lat
    );
}

GeoPosition CoordinateTransforms::ecefToGeo(const Vector3& ecef) const {
    double x = ecef.x, y = ecef.y, z = ecef.z;
    
    double lon_rad = atan2(y, x);
    double p = sqrt(x*x + y*y);
    double lat_rad = atan2(z, p * (1.0 - E2));
    
    double lat_prev;
    double alt = 0;
    double N = 0;
    
    do {
        lat_prev = lat_rad;
        N = A / sqrt(1.0 - E2 * sin(lat_rad) * sin(lat_rad));
        alt = p / cos(lat_rad) - N;
        lat_rad = atan2(z, p * (1.0 - E2 * N / (N + alt)));
    } while (fabs(lat_rad - lat_prev) > 1e-12);
    
    N = A / sqrt(1.0 - E2 * sin(lat_rad) * sin(lat_rad));
    alt = p / cos(lat_rad) - N;
    
    if (fabs(alt) < 1e-6) alt = 0;
    
    return GeoPosition(lat_rad * 180.0 / PI, lon_rad * 180.0 / PI, alt);
}

// ========== ECEF ↔ ECI ==========

double CoordinateTransforms::getSiderealTime(double time) const {
    return OMEGA * (time - origin_time);
}

Vector3 CoordinateTransforms::ecefToEci(const Vector3& ecef, double time) const {
    double theta = getSiderealTime(time);
    double cos_theta = cos(theta);
    double sin_theta = sin(theta);
    
    return Vector3(
        ecef.x * cos_theta - ecef.y * sin_theta,
        ecef.x * sin_theta + ecef.y * cos_theta,
        ecef.z
    );
}

Vector3 CoordinateTransforms::eciToEcef(const Vector3& eci, double time) const {
    double theta = getSiderealTime(time);
    double cos_theta = cos(theta);
    double sin_theta = sin(theta);
    
    return Vector3(
        eci.x * cos_theta + eci.y * sin_theta,
        -eci.x * sin_theta + eci.y * cos_theta,
        eci.z
    );
}

// ========== ECEF ↔ ENU ==========

Vector3 CoordinateTransforms::ecefToEnu(const Vector3& ecef, double lat, double lon) const {
    double lat_rad = lat * PI / 180.0;
    double lon_rad = lon * PI / 180.0;
    
    double sin_lat = sin(lat_rad);
    double cos_lat = cos(lat_rad);
    double sin_lon = sin(lon_rad);
    double cos_lon = cos(lon_rad);
    
    return Vector3(
        -ecef.x * sin_lon + ecef.y * cos_lon,
        -ecef.x * sin_lat * cos_lon - ecef.y * sin_lat * sin_lon + ecef.z * cos_lat,
        ecef.x * cos_lat * cos_lon + ecef.y * cos_lat * sin_lon + ecef.z * sin_lat
    );
}

Vector3 CoordinateTransforms::enuToEcef(const Vector3& enu, double lat, double lon) const {
    double lat_rad = lat * PI / 180.0;
    double lon_rad = lon * PI / 180.0;
    
    double sin_lat = sin(lat_rad);
    double cos_lat = cos(lat_rad);
    double sin_lon = sin(lon_rad);
    double cos_lon = cos(lon_rad);
    
    double east = enu.x;
    double north = enu.y;
    double up = enu.z;
    
    return Vector3(
        -east * sin_lon - north * sin_lat * cos_lon + up * cos_lat * cos_lon,
        east * cos_lon - north * sin_lat * sin_lon + up * cos_lat * sin_lon,
        north * cos_lat + up * sin_lat
    );
}

// ========== ENU ↔ BODY ==========

Vector3 CoordinateTransforms::enuToBody(const Vector3& enu, double roll, double pitch, double yaw) const {
    double phi = roll * PI / 180.0;
    double theta = pitch * PI / 180.0;
    double psi = yaw * PI / 180.0;
    
    double c_phi = cos(phi), s_phi = sin(phi);
    double c_theta = cos(theta), s_theta = sin(theta);
    double c_psi = cos(psi), s_psi = sin(psi);
    
    return Vector3(
        enu.x * (c_theta * c_psi) +
        enu.y * (c_theta * s_psi) +
        enu.z * (-s_theta),
        
        enu.x * (s_phi * s_theta * c_psi - c_phi * s_psi) +
        enu.y * (s_phi * s_theta * s_psi + c_phi * c_psi) +
        enu.z * (s_phi * c_theta),
        
        enu.x * (c_phi * s_theta * c_psi + s_phi * s_psi) +
        enu.y * (c_phi * s_theta * s_psi - s_phi * c_psi) +
        enu.z * (c_phi * c_theta)
    );
}

Vector3 CoordinateTransforms::bodyToEnu(const Vector3& body, double roll, double pitch, double yaw) const {
    double phi = roll * PI / 180.0;
    double theta = pitch * PI / 180.0;
    double psi = yaw * PI / 180.0;
    
    double c_phi = cos(phi), s_phi = sin(phi);
    double c_theta = cos(theta), s_theta = sin(theta);
    double c_psi = cos(psi), s_psi = sin(psi);
    
    double x = body.x, y = body.y, z = body.z;
    
    return Vector3(
        x * (c_theta * c_psi) +
        y * (s_phi * s_theta * c_psi - c_phi * s_psi) +
        z * (c_phi * s_theta * c_psi + s_phi * s_psi),
        
        x * (c_theta * s_psi) +
        y * (s_phi * s_theta * s_psi + c_phi * c_psi) +
        z * (c_phi * s_theta * s_psi - s_phi * c_psi),
        
        x * (-s_theta) +
        y * (s_phi * c_theta) +
        z * (c_phi * c_theta)
    );
}

// ========== ПОЛНЫЕ ПРЕОБРАЗОВАНИЯ ==========

GeoPosition CoordinateTransforms::eciToGeo(const Vector3& eci, double time) const {
    Vector3 ecef = eciToEcef(eci, time);
    return ecefToGeo(ecef);
}

Vector3 CoordinateTransforms::geoToEci(const GeoPosition& geo, double time) const {
    Vector3 ecef = geoToEcef(geo);
    return ecefToEci(ecef, time);
}

