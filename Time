#!/usr/bin/env python3
# -*- coding: utf-8 -*-

import csv
import math
import matplotlib.pyplot as plt
from collections import defaultdict

# ----------------------------------------------------------------
# 1. ВСПОМОГАТЕЛЬНЫЕ ФУНКЦИИ
# ----------------------------------------------------------------

def distance(p1, p2):
    return math.sqrt((p1[0]-p2[0])**2 + (p1[1]-p2[1])**2 + (p1[2]-p2[2])**2)

def cluster_points(points, dist_threshold):
    n = len(points)
    used = [False] * n
    clusters = []
    for i in range(n):
        if used[i]:
            continue
        cluster = [points[i]]
        used[i] = True
        changed = True
        while changed:
            changed = False
            for j in range(n):
                if used[j]:
                    continue
                for p in cluster:
                    if distance(p, points[j]) < dist_threshold:
                        cluster.append(points[j])
                        used[j] = True
                        changed = True
                        break
        clusters.append(cluster)
    return clusters

def compute_center(cluster):
    n = len(cluster)
    if n == 0:
        return None
    sum_x = sum(p[0] for p in cluster)
    sum_y = sum(p[1] for p in cluster)
    sum_z = sum(p[2] for p in cluster)
    return (sum_x/n, sum_y/n, sum_z/n)

def bounding_box(cluster):
    xs = [p[0] for p in cluster]
    ys = [p[1] for p in cluster]
    return (min(xs), min(ys), max(xs), max(ys))

# ----------------------------------------------------------------
# 2. ЧТЕНИЕ CSV С ГРУППИРОВКОЙ ПО КАДРАМ (200 мс)
# ----------------------------------------------------------------

def parse_time(time_str):
    parts = time_str.split(':')
    if len(parts) != 3:
        return None
    try:
        hours = float(parts[0])
        minutes = float(parts[1])
        seconds = float(parts[2])
        return hours * 3600 + minutes * 60 + seconds
    except ValueError:
        return None

def read_livox_csv(file_path, frame_duration=0.2):
    all_points = []
    with open(file_path, 'r') as f:
        reader = csv.reader(f)
        next(reader, None)  # пропускаем заголовок
        for row in reader:
            if len(row) < 5:
                continue
            try:
                time_str = row[0].strip()
                time_sec = parse_time(time_str)
                if time_sec is None:
                    continue
                x = float(row[1])
                y = float(row[2])
                z = float(row[3])
                intensity = float(row[4])
                all_points.append((time_sec, x, y, z, intensity))
            except ValueError:
                continue

    if not all_points:
        return []

    all_points.sort(key=lambda p: p[0])
    min_time = all_points[0][0]
    max_time = all_points[-1][0]
    frames = []
    start = min_time
    while start <= max_time:
        end = start + frame_duration
        frame_points = [
            (x, y, z, intensity)
            for (t, x, y, z, intensity) in all_points
            if start <= t < end
        ]
        frames.append((start, frame_points))
        start = end
    return frames

# ----------------------------------------------------------------
# 3. ОБРАБОТКА КАДРОВ (кластеризация, центры, боксы)
# ----------------------------------------------------------------

def process_frames(frames, intensity_threshold=240, cluster_dist=0.15):
    processed = []
    for time, points in frames:
        bright = [p for p in points if p[3] >= intensity_threshold]
        if len(bright) < 3:
            processed.append({'time': time, 'clusters': [], 'centers': [], 'bboxes': []})
            continue
        clusters = cluster_points(bright, cluster_dist)
        clusters = [c for c in clusters if len(c) >= 3]
        centers = [compute_center(c) for c in clusters]
        bboxes = [bounding_box(c) for c in clusters]
        processed.append({
            'time': time,
            'clusters': clusters,
            'centers': centers,
            'bboxes': bboxes
        })
    return processed

# ----------------------------------------------------------------
# 4. ВИЗУАЛИЗАЦИЯ БЕЗ ТРЕКИНГА (только кластеры и центры)
# ----------------------------------------------------------------

def visualize(processed_frames):
    fig, ax = plt.subplots(figsize=(12, 10))
    num_frames = len(processed_frames)
    frame_colors = [plt.cm.viridis(i / max(1, num_frames-1)) for i in range(num_frames)]

    for f_idx, frame_data in enumerate(processed_frames):
        # Все точки кадра
        all_points = []
        for cl in frame_data['clusters']:
            all_points.extend(cl)
        if all_points:
            xs = [p[0] for p in all_points]
            ys = [p[1] for p in all_points]
            ax.scatter(xs, ys, c=[frame_colors[f_idx]]*len(xs), s=2, alpha=0.3)

        # Кластеры и боксы
        for cl, center, bbox in zip(frame_data['clusters'], frame_data['centers'], frame_data['bboxes']):
            if center is None:
                continue
            cl_xs = [p[0] for p in cl]
            cl_ys = [p[1] for p in cl]
            ax.scatter(cl_xs, cl_ys, c=[frame_colors[f_idx]]*len(cl_xs), s=10, alpha=0.7)
            x_min, y_min, x_max, y_max = bbox
            rect = plt.Rectangle((x_min, y_min), x_max-x_min, y_max-y_min,
                                 fill=False, edgecolor=frame_colors[f_idx], linewidth=1)
            ax.add_patch(rect)
            ax.scatter(center[0], center[1], c='red', marker='x', s=60, linewidths=2)

    ax.set_xlabel('X (м)')
    ax.set_ylabel('Y (м)')
    ax.set_title('Детекция маркеров (без трекинга): кластеры и центры')
    ax.axis('equal')
    ax.grid(True, alpha=0.3)
    plt.show()

# ----------------------------------------------------------------
# 5. ГЛАВНАЯ ФУНКЦИЯ
# ----------------------------------------------------------------

def main():
    CSV_PATH = "path/to/your/file.csv"
    FRAME_DURATION = 0.2          # 200 мс
    INTENSITY_THRESHOLD = 240
    CLUSTER_DIST = 0.15

    frames = read_livox_csv(CSV_PATH, frame_duration=FRAME_DURATION)
    print(f"Сформировано кадров: {len(frames)}")

    processed = process_frames(frames, INTENSITY_THRESHOLD, CLUSTER_DIST)

    # Подсчёт суммарного количества кластеров по всем кадрам
    total_clusters = sum(len(fd['clusters']) for fd in processed)
    print(f"Всего обнаружено кластеров (по всем кадрам): {total_clusters}")

    visualize(processed)

if __name__ == "__main__":
    main()
