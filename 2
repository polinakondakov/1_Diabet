// ==================== КОНСТРУКТОР ====================
TrajectoryGenerator::TrajectoryGenerator(const TrajectoryConfig& cfg) : config(cfg) {
    // Инициализируем преобразования начальной точкой
    transforms.init(config.start_geo_position, 0);
    
    cout << "\n=== TRAJECTORY GENERATOR INIT ===" << endl;
    cout << "Start geo: (" << config.start_geo_position.latitude 
         << ", " << config.start_geo_position.longitude 
         << ", " << config.start_geo_position.altitude << ")" << endl;
    
    Vector3 start_eci = transforms.geoToEci(config.start_geo_position, 0);
    cout << "Start ECI: (" << start_eci.x << ", " << start_eci.y << ", " << start_eci.z << ")" << endl;
    cout << "===================================" << endl;
}

// ==================== buildWithSmoothing ====================
vector<TrajectoryPoint> TrajectoryGenerator::buildWithSmoothing(double max_normal_acc) {
    cout << "\n========== BUILD WITH SMOOTHING ==========" << endl;
    cout << "max_normal_acc = " << max_normal_acc << endl;
    cout << "time_step = " << config.time_step << endl;
    cout << "segments count = " << config.segments.size() << endl;
    
    if (config.witch_from) {
        cout << "Loading from file..." << endl;
        return loadFromFile(config.file_path);
    }
    
    vector<TrajectoryPoint> trajectory;
    double current_time = 0;
    
    if (config.segments.empty()) {
        cout << "No segments for generation" << endl;
        return trajectory;
    }
    
    // ===== НАЧАЛЬНАЯ АБСОЛЮТНАЯ ПОЗИЦИЯ В ECI =====
    Vector3 abs_pos_eci = transforms.geoToEci(config.start_geo_position, 0);
    Vector3 abs_pos_eci_start = abs_pos_eci;
    Vector3 current_vel(0, 0, 0);
    
    cout << "\n=== INITIAL ABSOLUTE ECI POSITION ===" << endl;
    cout << "abs_pos_eci = (" << abs_pos_eci.x << ", " << abs_pos_eci.y << ", " << abs_pos_eci.z << ")" << endl;
    cout << "=====================================" << endl;
    
    int total_points = 0;
    
    for (size_t i = 0; i < config.segments.size(); i++) {
        auto& seg = config.segments[i];
        double duration = seg->duration;
        
        cout << "\n--- SEGMENT " << i << " ---" << endl;
        cout << "Type: " << seg->getType() << ", Duration: " << duration << endl;
        cout << "abs_pos_eci before segment: (" << abs_pos_eci.x << ", " << abs_pos_eci.y << ")" << endl;
        
        int point_in_segment = 0;
        
        // ===== ГЕНЕРАЦИЯ ТОЧЕК СЕГМЕНТА =====
        for (double t = 0; t <= duration; t += config.time_step) {
            if (t > duration) t = duration;
            
            // Текущая скорость и абсолютная позиция
            current_vel = seg->velocity(t);
            Vector3 local_pos = seg->position(t);
            Vector3 current_abs_eci = abs_pos_eci + local_pos;
            
            // ОТЛАДКА: первые 5 точек в сегменте
            if (point_in_segment < 5) {
                cout << "\n  [POINT " << point_in_segment << "] t=" << t << endl;
                cout << "    local_pos = (" << local_pos.x << ", " << local_pos.y << ")" << endl;
                cout << "    current_abs_eci = (" << current_abs_eci.x << ", " << current_abs_eci.y << ")" << endl;
                
                // Проверка ECEF
                Vector3 ecef = transforms.eciToEcef(current_abs_eci, current_time + t);
                cout << "    ecef = (" << ecef.x << ", " << ecef.y << ", " << ecef.z << ")" << endl;
                
                // Проверка географических координат
                GeoPosition geo = transforms.ecefToGeo(ecef);
                cout << "    geo from ecef = (" << geo.latitude << ", " << geo.longitude << ")" << endl;
                
                point_in_segment++;
            }
            
            TrajectoryPoint point(current_time + t);
            point.position_eci = current_abs_eci;
            point.velocity_eci = current_vel;
            point.acceleration_eci = seg->acceleration(t);
            point.orientation = seg->orientation(t);
            point.angular_velocity = seg->angular_velocity(t);
            
            // Преобразование ECI → Географические
            point.geo_position = transforms.eciToGeo(current_abs_eci, current_time + t);
            
            // ОТЛАДКА: первые 5 точек
            if (point_in_segment <= 5) {
                cout << "    point.geo = (" << point.geo_position.latitude << ", " 
                     << point.geo_position.longitude << ")" << endl;
            }
            
            trajectory.push_back(point);
            total_points++;
        }
        
        // Обновляем абсолютную позицию для следующего сегмента
        abs_pos_eci = abs_pos_eci + seg->position(duration);
        current_time += duration;
        
        cout << "abs_pos_eci after segment: (" << abs_pos_eci.x << ", " << abs_pos_eci.y << ")" << endl;
        cout << "current_time = " << current_time << endl;
        
        // ===== ПЛАВНЫЙ ПОВОРОТ =====
        if (i < config.segments.size() - 1) {
            Vector3 endVel = seg->velocity(duration);
            Vector3 nextVel = config.segments[i+1]->velocity(0);
            
            double turn_duration = 1.0;
            if (seg->getType() == 3 || config.segments[i+1]->getType() == 3) {
                turn_duration = 0.3;
            }
            
            cout << "\n  --- SMOOTH TURN ---" << endl;
            cout << "  turn_duration = " << turn_duration << endl;
            cout << "  endVel = (" << endVel.x << ", " << endVel.y << ")" << endl;
            cout << "  nextVel = (" << nextVel.x << ", " << nextVel.y << ")" << endl;
            
            SmoothTurn turn(endVel, nextVel, turn_duration, max_normal_acc);
            
            // Начальная позиция поворота (абсолютная)
            Vector3 turn_start_pos = abs_pos_eci;
            cout << "  turn_start_pos = (" << turn_start_pos.x << ", " << turn_start_pos.y << ")" << endl;
            
            int turn_point_count = 0;
            for (double t = config.time_step; t <= turn.duration; t += config.time_step) {
                if (t > turn.duration) t = turn.duration;
                
                Vector3 vel = turn.getVel(t);
                Vector3 pos = turn_start_pos + vel * t;
                
                if (turn_point_count < 3) {
                    cout << "  [TURN POINT] t=" << t << " vel=(" << vel.x << "," << vel.y 
                         << ") pos=(" << pos.x << "," << pos.y << ")" << endl;
                    turn_point_count++;
                }
                
                TrajectoryPoint point(current_time + t);
                point.position_eci = pos;
                point.velocity_eci = vel;
                point.geo_position = transforms.eciToGeo(pos, current_time + t);
                
                trajectory.push_back(point);
                total_points++;
            }
            
            // Обновляем позицию и время после поворота
            abs_pos_eci = turn_start_pos + turn.getVel(turn.duration) * turn.duration;
            current_time += turn.duration;
            
            cout << "  abs_pos_eci after turn: (" << abs_pos_eci.x << ", " << abs_pos_eci.y << ")" << endl;
        }
    }
    
    cout << "\n========== GENERATION COMPLETE ==========" << endl;
    cout << "Total points: " << total_points << endl;
    cout << "=========================================" << endl;
    
    return trajectory;
}

// ==================== ОСТАЛЬНЫЕ МЕТОДЫ (без изменений) ====================

vector<TrajectoryPoint> TrajectoryGenerator::loadFromFile(const string& filename) {
    ifstream file;
    file.open(filename);
    vector<TrajectoryPoint> traj;
    
    if (!file.is_open()) {
        cout << "Error file isn't open " << filename << endl;
        return traj;
    }
    
    string line;
    getline(file, line);  // пропускаем заголовок
    
    while (getline(file, line)) {
        if (line.empty()) continue;
        
        stringstream ss(line);
        vector<double> values;
        string val;
        while (getline(ss, val, ',')) {
            values.push_back(stod(val));
        }
        
        if (values.size() >= 7) {
            TrajectoryPoint p(values[0]);
            p.geo_position = GeoPosition(values[1], values[2], values[3]);
            p.position_eci = transforms.geoToEci(p.geo_position, values[0]);
            p.orientation = Vector3(values[4], values[5], values[6]);
            traj.push_back(p);
        }
    }
    
    computeDerivatives(traj);
    file.close();
    return traj;
}

void TrajectoryGenerator::computeDerivatives(vector<TrajectoryPoint>& traj) {
    if (traj.size() < 2) return;
    
    double dt = traj[1].time - traj[0].time;
    
    for (size_t i = 0; i < traj.size() - 1; i++) {
        traj[i].velocity_eci = (traj[i+1].position_eci - traj[i].position_eci) / dt;
        traj[i].acceleration_eci = (traj[i+1].velocity_eci - traj[i].velocity_eci) / dt;
        
        Vector3 dTheta = traj[i+1].orientation - traj[i].orientation;
        traj[i].angular_velocity = Vector3(dTheta.x/dt, dTheta.y/dt, dTheta.z/dt);
    }
    
    traj[traj.size() - 1].velocity_eci = traj[traj.size() - 2].velocity_eci;
    traj[traj.size() - 1].acceleration_eci = traj[traj.size() - 2].acceleration_eci;
    traj[traj.size() - 1].angular_velocity = traj[traj.size() - 2].angular_velocity;
}

void TrajectoryGenerator::addStraight(double duration, Vector3 start_pos, Vector3 start_vel, Vector3 acc, double angle) {
    config.segments.push_back(make_shared<StraightSegment>(duration, start_pos, start_vel, acc, angle));
}

void TrajectoryGenerator::addSnake(double duration, Vector3 start_pos, double forward_vel, double amplitude, double frequency) {
    config.segments.push_back(make_shared<SnakeSegment>(duration, start_pos, forward_vel, amplitude, frequency));
}

void TrajectoryGenerator::addCircle(double duration, Vector3 center, double radius, double angular_vel, double start_angle) {
    config.segments.push_back(make_shared<CircleSegment>(duration, center, radius, angular_vel, start_angle));
}

vector<TrajectoryPoint> TrajectoryGenerator::build() {
    if (config.witch_from) {
        return loadFromFile(config.file_path);
    }
    return buildWithSmoothing(100.0);
}
